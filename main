import math

class Figure:
    def perimeter(self):
        raise NotImplementedError
    def square(self):
        raise NotImplementedError
    def volume(self):
        return 0

class Circle(Figure):
    def __init__(self, r):
        self.r = r
    def perimeter(self):
        return 2 * math.pi * self.r
    def square(self):
        return math.pi * self.r ** 2
        
class Rectangle(Figure):
    def __init__(self, a, b):
        self.a = a
        self.b = b
    def perimeter(self):
        return 2 * (self.a + self.b)
    def square(self):
        return self.a * self.b
        
class Triangle(Figure):
    def __init__(self, a, b, c):
        self.a = a
        self.b = b
        self.c = c
    def perimeter(self):
        return self.a + self.b + self.c
    def square(self):
        p = self.perimeter() / 2
        return math.sqrt(p * (p - self.a) * (p - self.b) * (p - self.c))

figures = []
for i in range(1, 4):
    file = f"input0{i}.txt"
    with open(file) as f:
        for line in f:
            parts = line.split()
            name = parts[0]
            if name == "Circle":
                figures.append(Circle(float(parts[1])))
            elif name == "Rectangle":
                figures.append(Rectangle(float(parts[1]), float(parts[2])))
            elif name == "Triangle":
                figures.append(Triangle(float(parts[1]), float(parts[2]), float(parts[3])))

max_area = 0
max_type = ""
for fig in figures:
    area = fig.square()
    if area > max_area:
        max_area = area
        max_type = type(fig).__name__
with open("output.txt", "w") as f:
    f.write(f"Max area: {max_area}\n")
    f.write(f"Figure type: {max_type}")
